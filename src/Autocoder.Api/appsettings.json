{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=autocoder.db"
  },
  "Claude": {
    "CliPath": "claude",
    "DefaultMaxTurns": 10
  },
  "Git": {
    "WorktreeBaseDir": "C:\\autocoder-worktrees"
  },
  "Orchestrator": {
    "MaxConcurrency": 3,
    "PollIntervalMs": 1000
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
